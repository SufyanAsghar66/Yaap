# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-min-50-chars-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # Never expose to clients!

# ─── Database (Supabase PostgreSQL direct connection) ─────────────────────────
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Firebase (FCM Push Notifications) ───────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ─── DeepL Translation ────────────────────────────────────────────────────────
DEEPL_API_KEY=your-deepl-api-key

# ─── XTTS Microservice ────────────────────────────────────────────────────────
XTTS_SERVICE_URL=http://xtts-service:8001
WHISPER_SERVICE_URL=http://whisper-service:8002

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ─── Storage ──────────────────────────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET_AVATARS=avatars
SUPABASE_STORAGE_BUCKET_VOICE_SAMPLES=voice-samples

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
OTP_EXPIRY_MINUTES=10

# ─── coturn TURN Server ───────────────────────────────────────────────────────
COTURN_HOST=turn.yaap.app
COTURN_PORT=3478
COTURN_SECRET=your-long-random-coturn-secret-min-32-chars
