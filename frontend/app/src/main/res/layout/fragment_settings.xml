<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Profile header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/color_primary"
            android:paddingTop="40dp"
            android:paddingBottom="24dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="80dp"
                android:layout_height="80dp"/>

            <TextView
                android:id="@+id/tv_display_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tv_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#AAFFFFFF"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Settings rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textSize="13sp" android:textColor="@color/color_muted_text"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                style="@style/Widget.Yaap.Card"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout android:id="@+id/row_edit_name"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/row_edit_name"
                            android:textSize="15sp" android:textColor="@color/color_dark_text"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right" android:tint="@color/color_muted_text"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/color_border" android:layout_marginStart="16dp"/>
                    <LinearLayout android:id="@+id/row_edit_bio"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/row_edit_bio"
                            android:textSize="15sp" android:textColor="@color/color_dark_text"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right" android:tint="@color/color_muted_text"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/color_border" android:layout_marginStart="16dp"/>
                    <LinearLayout android:id="@+id/row_change_language"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/row_change_language"
                            android:textSize="15sp" android:textColor="@color/color_dark_text"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right" android:tint="@color/color_muted_text"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Voice section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Voice" android:textSize="13sp" android:textColor="@color/color_muted_text"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                style="@style/Widget.Yaap.Card"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout android:id="@+id/row_re_record_voice"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/row_re_record_voice"
                        android:textSize="15sp" android:textColor="@color/color_dark_text"/>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right" android:tint="@color/color_muted_text"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Privacy section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Privacy" android:textSize="13sp" android:textColor="@color/color_muted_text"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                style="@style/Widget.Yaap.Card"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="16dp" android:paddingEnd="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/row_read_receipts"
                            android:textSize="15sp" android:textColor="@color/color_dark_text"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_read_receipts"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/color_border" android:layout_marginStart="16dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="16dp" android:paddingEnd="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/row_online_status"
                            android:textSize="15sp" android:textColor="@color/color_dark_text"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_online_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Logout -->
            <Button
                android:id="@+id/btn_logout"
                style="@style/Widget.Yaap.Button.Danger"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/btn_logout"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tv_app_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textSize="12sp"
                android:textColor="@color/color_muted_text"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
