<?xml version="1.0" encoding="utf-8"?>
<resources>
<!-- Base application theme -->
<style name="Theme.Yaap" parent="Theme.MaterialComponents.DayNight.NoActionBar">
    <item name="colorPrimary">@color/color_primary</item>
    <item name="colorPrimaryVariant">@color/color_primary_dark</item>
    <item name="colorSecondary">@color/color_secondary</item>
    <item name="colorOnPrimary">@color/white</item>
    <item name="colorOnSecondary">@color/white</item>
    <item name="android:colorBackground">@color/color_surface</item>
    <item name="android:windowBackground">@color/color_surface</item>
    <item name="android:fontFamily">@font/poppins_regular</item>
    <item name="android:statusBarColor">@color/color_primary</item>
    <item name="android:navigationBarColor">@color/white</item>
</style>

<!-- Splash theme - no flicker -->
<style name="Theme.Yaap.Splash" parent="Theme.Yaap">
    <item name="android:windowBackground">@drawable/splash_background</item>
    <item name="android:windowFullscreen">false</item>
</style>

<!-- Auth theme -->
<style name="Theme.Yaap.Auth" parent="Theme.Yaap" />

<!-- Call theme - full screen dark -->
<style name="Theme.Yaap.Call" parent="Theme.Yaap">
    <item name="android:windowBackground">@color/color_primary</item>
    <item name="android:statusBarColor">@color/color_primary</item>
</style>

<!-- ─── Component Styles ─────────────────────────────── -->

<!-- YaapButton - Primary pill -->
<style name="Widget.Yaap.Button.Primary" parent="Widget.MaterialComponents.Button">
    <item name="android:textColor">@color/white</item>
    <item name="backgroundTint">@color/color_secondary</item>
    <item name="android:textSize">15sp</item>
    <item name="android:textStyle">bold</item>
    <item name="cornerRadius">26dp</item>
    <item name="android:minHeight">52dp</item>
    <item name="android:paddingStart">24dp</item>
    <item name="android:paddingEnd">24dp</item>
    <item name="android:letterSpacing">0.02</item>
</style>

<!-- YaapButton - Outline pill -->
<style name="Widget.Yaap.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
    <item name="android:textColor">@color/color_secondary</item>
    <item name="strokeColor">@color/color_secondary</item>
    <item name="android:textSize">15sp</item>
    <item name="cornerRadius">26dp</item>
    <item name="android:minHeight">52dp</item>
    <item name="android:paddingStart">24dp</item>
    <item name="android:paddingEnd">24dp</item>
</style>

<!-- YaapButton - Danger -->
<style name="Widget.Yaap.Button.Danger" parent="Widget.Yaap.Button.Outline">
    <item name="android:textColor">@color/color_danger</item>
    <item name="strokeColor">@color/color_danger</item>
</style>

<!-- YaapCard -->
<style name="Widget.Yaap.Card" parent="Widget.MaterialComponents.CardView">
    <item name="cardBackgroundColor">@color/color_card_bg</item>
    <item name="cardCornerRadius">12dp</item>
    <item name="cardElevation">2dp</item>
    <item name="strokeColor">@color/color_border</item>
    <item name="strokeWidth">0.5dp</item>
    <item name="contentPadding">16dp</item>
</style>

<!-- TextInput -->
<style name="Widget.Yaap.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
    <item name="boxCornerRadiusTopStart">4dp</item>
    <item name="boxCornerRadiusTopEnd">4dp</item>
    <item name="boxCornerRadiusBottomStart">4dp</item>
    <item name="boxCornerRadiusBottomEnd">4dp</item>
    <item name="boxStrokeColor">@color/color_border</item>
    <item name="hintTextColor">@color/color_muted_text</item>
</style>

<!-- ─── Text Styles ──────────────────────────────────── -->

<style name="TextAppearance.Yaap.Display" parent="TextAppearance.MaterialComponents.Headline4">
    <item name="android:textSize">28sp</item>
    <item name="android:textStyle">bold</item>
    <item name="android:textColor">@color/color_dark_text</item>
</style>

<style name="TextAppearance.Yaap.Title" parent="TextAppearance.MaterialComponents.Headline5">
    <item name="android:textSize">22sp</item>
    <item name="android:textStyle">bold</item>
    <item name="android:textColor">@color/color_dark_text</item>
</style>

<style name="TextAppearance.Yaap.SectionHeader" parent="TextAppearance.MaterialComponents.Subtitle1">
    <item name="android:textSize">18sp</item>
    <item name="android:textColor">@color/color_dark_text</item>
</style>

<style name="TextAppearance.Yaap.Body" parent="TextAppearance.MaterialComponents.Body1">
    <item name="android:textSize">15sp</item>
    <item name="android:textColor">@color/color_dark_text</item>
</style>

<style name="TextAppearance.Yaap.Caption" parent="TextAppearance.MaterialComponents.Caption">
    <item name="android:textSize">12sp</item>
    <item name="android:textColor">@color/color_muted_text</item>
</style>

<style name="TextAppearance.Yaap.TabText" parent="TextAppearance.MaterialComponents.Button">
    <item name="android:textSize">14sp</item>
    <item name="android:textAllCaps">false</item>
    <item name="android:fontFamily">sans-serif-medium</item>
</style>
</resources>